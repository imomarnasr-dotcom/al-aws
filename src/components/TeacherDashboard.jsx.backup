              </div>

              {/* ًں”¥ ط§ظ„ظپظ„طھط± ط§ظ„ظ…ظˆط­ط¯ - ظپطµظ„ ظˆط§ط­ط¯ ظپظ‚ط· */}
              <div className="flex gap-4 mb-8 bg-gray-50 p-6 rounded-[32px] border border-gray-100">
