                        const lessonTime = parseTime(lesson.time);
                        const hasStarted = lessonTime ? nowTime >= lessonTime : true;

                        let cardClass = "";
                        let onClickHandler = null;

                        if (isTaken) {
                           cardClass = "bg-emerald-50 border-emerald-200 text-emerald-800 hover:bg-emerald-100";
